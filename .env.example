# MT5 terminal to use
MT5_TERMINAL_PATH="C:\Program Files\TTP Trading MT5 Terminal\terminal64.exe"

# Shared raw CSV updated from MT5
MT5_DATA_PATH=data/raw/BTCUSD_1h_mt5.csv
MT5_SYNC_DATA_TO_CSV=1
MT5_FULL_SYNC_ON_START=1
MT5_HISTORY_START=2010-01-01T00:00:00Z
MT5_SYNC_CHUNK_DAYS=365
MT5_SYNC_OVERLAP_BARS=336

# Live strategy risk per trade
MT5_RISK_PER_TRADE_PCT=0.014

# Maximum broker margin as a fraction of current MT5 equity
MT5_MAX_MARGIN_PCT=0.175

# Optional live settings
MT5_SYMBOL=BTCUSD
MT5_TIMEFRAME=H1
MT5_COOLDOWN_HOURS=24
MT5_MAX_TICK_AGE_SECONDS=180
MT5_MAX_SPREAD_BPS=15
